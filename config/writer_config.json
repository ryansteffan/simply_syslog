{
	"version": "1.0.0",
	"writers": [
		{
			"name": "console",
			"enabled": true,
			"options": {
				"format": "raw"
			}
		},
		{
			"name": "file",
			"enabled": true,
			"options": {
				"path": "./logs/app.log"
			}
		},
		{
			"name": "duckdb",
			"enabled": true,
			"options": {
				"path": "/syslog/syslog.db"
			}
		}
	]
}
